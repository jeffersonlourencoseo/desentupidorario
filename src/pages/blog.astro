---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout
  title="Blog | Desentupidora Rio de Janeiro"
  description="Dicas e orientações sobre desentupimento, limpeza de fossa, caixa de gordura e cuidados com encanamento no Rio de Janeiro.">
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <PageHeader
        eyebrow="Blog"
        title="Dicas de desentupimento e limpeza"
        description="Conteúdo prático para você evitar entupimentos, identificar problemas no encanamento e manter a casa ou empresa em ordem."
      />

      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
        {sortedPosts.map((post) => (
          <article class="rounded-2xl border border-primary-100 bg-white p-10 shadow-sm transition-all hover:-translate-y-1 hover:border-secondary/30 hover:shadow-lg">
            <span class="text-xs font-bold tracking-wider text-primary-700 uppercase">
              {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
            </span>
            <h2 class="mt-3 font-display text-xl font-bold text-text">
              <a href={`/blog/${post.id.replace(/\.md$/, '').replace(/\//g, '-')}/`} class="hover:text-primary transition-colors">
                {post.data.title}
              </a>
            </h2>
            <p class="mt-3 leading-relaxed text-muted">
              {post.data.description}
            </p>
            <a
              href={`/blog/${post.id.replace(/\.md$/, '').replace(/\//g, '-')}/`}
              class="mt-6 inline-flex items-center font-semibold text-primary hover:text-primary-600 transition-colors"
            >
              Ler artigo
              <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
