---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SchemaBreadcrumbs from '../../components/seo/SchemaBreadcrumbs.astro';
import SchemaService from '../../components/seo/SchemaService.astro';
import { SITE_CONFIG, whatsappLink, phoneLink } from '../../data/config.ts';

export async function getStaticPaths() {
  const services = await getCollection('servicos');
  return services.map((service) => ({
    params: { slug: service.id.replace(/\.md$/, '').replace(/\//g, '-') },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

const allServices = await getCollection('servicos');

const serviceName = service.data.title.replace(' no Rio de Janeiro', '');
const shortName = serviceName.replace('Desentupimento de ', '').replace('Limpeza de ', '');
const slug = Astro.params.slug;
const serviceUrl = `${SITE_CONFIG.domain}/servicos/${slug}/`;

const relatedServices = allServices
  .filter((s) => s.id !== service.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const breadcrumbs = [
  { name: 'Início', url: '/' },
  { name: 'Serviços', url: '/servicos/' },
  { name: serviceName, url: `/servicos/${slug}/`, current: true },
];
---

<Layout
  title={service.data.title}
  description={service.data.description}>

  <SchemaService
    name={service.data.title}
    description={service.data.description}
    url={serviceUrl}
  />
  <SchemaBreadcrumbs items={breadcrumbs} />
  <Breadcrumbs items={breadcrumbs} />

  <!-- Hero do serviço -->
  <section class="relative overflow-hidden bg-ink py-24 text-white md:py-32">
    <div class="container relative mx-auto px-6 lg:px-12">
      <div class="mx-auto max-w-4xl text-center">
        <a href="/servicos/" class="mb-6 inline-flex items-center text-sm font-semibold text-white/80 hover:text-white">
          <svg class="mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7" />
          </svg>
          Ver todos os serviços
        </a>

        <span class="mb-3 block text-sm font-bold tracking-wider text-signal uppercase">Serviço</span>
        <h1 class="font-display text-4xl font-extrabold leading-tight md:text-5xl">
          {service.data.title}
        </h1>
        <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-white/80 md:text-xl">
          {service.data.description}
        </p>
      </div>
    </div>
  </section>

  <article class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mx-auto max-w-5xl">
        <!-- Conteúdo do markdown -->
        <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-text prose-a:text-alert hover:prose-a:text-alert-600">
          <Content />
        </div>

        <!-- Especificações técnicas -->
        <div class="mt-16 border-2 border-steel bg-white p-10 shadow-[6px_6px_0px_0px_rgba(225,231,236,1)]">
          <h2 class="mb-8 font-display text-2xl font-bold text-text">
            Como funciona o {serviceName.toLowerCase()}
          </h2>
          <div class="grid gap-8 md:grid-cols-3">
            <div class="space-y-3">
              <div class="flex h-12 w-12 items-center justify-center border-2 border-steel bg-concrete font-display text-xl font-bold text-ink">1</div>
              <h3 class="font-display text-lg font-bold text-text">Contato</h3>
              <p class="text-muted">Você nos chama pelo WhatsApp ou telefone e descreve o problema.</p>
            </div>
            <div class="space-y-3">
              <div class="flex h-12 w-12 items-center justify-center border-2 border-steel bg-concrete font-display text-xl font-bold text-ink">2</div>
              <h3 class="font-display text-lg font-bold text-text">Diagnóstico</h3>
              <p class="text-muted">Nossa equipe avalia a causa do entupimento e apresenta o orçamento.</p>
            </div>
            <div class="space-y-3">
              <div class="flex h-12 w-12 items-center justify-center border-2 border-steel bg-concrete font-display text-xl font-bold text-ink">3</div>
              <h3 class="font-display text-lg font-bold text-text">Execução</h3>
              <p class="text-muted">Resolvemos o problema com equipamento adequado e limpamos o local.</p>
            </div>
          </div>
        </div>

        <!-- Benefícios -->
        <div class="mt-16 border-2 border-steel bg-concrete p-10">
          <h2 class="mb-8 font-display text-2xl font-bold text-text">
            Benefícios do {serviceName.toLowerCase()} com garantia
          </h2>
          <ul class="grid gap-4 md:grid-cols-2">
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-signal">✓</span>
              Atendimento 24h, inclusive feriados.
            </li>
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-signal">✓</span>
              Equipes espalhadas por todas as zonas do Rio de Janeiro.
            </li>
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-signal">✓</span>
              Orçamento grátis e sem compromisso.
            </li>
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-signal">✓</span>
              Equipamento profissional para cada tipo de entupimento.
            </li>
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-signal">✓</span>
              Garantia no serviço e reajuste sem custo se necessário.
            </li>
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-signal">✓</span>
              Local limpo e organizado ao final do trabalho.
            </li>
          </ul>
        </div>

        <!-- Regiões atendidas -->
        <div class="mt-16 border-2 border-steel bg-white p-10 shadow-[6px_6px_0px_0px_rgba(225,231,236,1)]">
          <h2 class="mb-6 font-display text-2xl font-bold text-text">
            {serviceName} em todas as regiões do Rio
          </h2>
          <p class="mb-6 text-muted">
            Atendemos Zona Norte, Zona Sul, Zona Oeste, Centro, Tijuca, Copacabana,
            Barra da Tijuca, Madureira, Campo Grande e todos os bairros do Rio de Janeiro.
            Onde você estiver, levamos uma equipe com equipamento profissional.
          </p>
          <a href="/contato/" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wide text-alert transition-colors hover:text-alert-600">
            Ver canais de atendimento
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Serviços relacionados -->
        {relatedServices.length > 0 && (
          <div class="mt-16 border-2 border-steel bg-white p-10 shadow-[6px_6px_0px_0px_rgba(225,231,236,1)]">
            <h2 class="mb-8 font-display text-2xl font-bold text-text">Serviços relacionados</h2>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {relatedServices.map((related) => (
                <a href={`/servicos/${related.id.replace(/\.md$/, '').replace(/\//g, '-')}/`} class="block group">
                  <ServiceCard
                    title={related.data.title.replace(' no Rio de Janeiro', '')}
                    description={related.data.description}
                    icon={related.data.icon || ''}
                  />
                </a>
              ))}
            </div>          </div>
        )}

        <!-- CTA de fechamento -->
        <div class="mt-16 border-4 border-white bg-ink p-12 text-center text-white shadow-[12px_12px_0px_0px_rgba(217,92,30,1)] md:p-16">
          <h2 class="mb-4 font-display text-3xl font-bold md:text-4xl">
            Solicite {serviceName.toLowerCase()} agora
          </h2>
          <p class="mx-auto mb-8 max-w-2xl text-lg text-white/70">
            Fale conosco agora e receba atendimento 24h no Rio de Janeiro. Orçamento grátis,
            chegada rápida e garantia real no serviço.
          </p>
          <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
            <Button href={whatsappLink()} variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
              Chamar no WhatsApp
            </Button>
            <Button href={phoneLink()} variant="outline" size="lg">
              Ligar: {SITE_CONFIG.phone.replace('+55', '').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3')}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </article>
</Layout>
