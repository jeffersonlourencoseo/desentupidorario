---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { SITE_CONFIG, whatsappLink, phoneLink } from '../../data/config.ts';

export async function getStaticPaths() {
  const services = await getCollection('servicos');
  return services.map((service) => ({
    params: { slug: service.id.replace(/\.md$/, '').replace(/\//g, '-') },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

const serviceName = service.data.title.replace(' no Rio de Janeiro', '');
const shortName = serviceName.replace('Desentupimento de ', '').replace('Limpeza de ', '');
---

<Layout
  title={service.data.title}
  description={service.data.description}>

  <!-- Hero do serviço -->
  <section class="relative overflow-hidden bg-primary py-24 text-white md:py-32">
    <div class="container relative mx-auto px-6 lg:px-12">
      <div class="mx-auto max-w-4xl text-center">
        <a href="/servicos/" class="mb-6 inline-flex items-center text-sm font-semibold text-primary-100 hover:text-white">
          <svg class="mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7" />
          </svg>
          Ver todos os serviços
        </a>

        <span class="mb-3 block text-sm font-bold tracking-wider text-primary-700 uppercase">Serviço</span>
        <h1 class="font-display text-4xl font-extrabold leading-tight md:text-5xl">
          {service.data.title}
        </h1>
        <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-primary-50 md:text-xl">
          {service.data.description}
        </p>
      </div>
    </div>
  </section>

  <article class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mx-auto max-w-5xl">
        <!-- Conteúdo do markdown -->
        <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-text prose-a:text-primary hover:prose-a:text-primary-600">
          <Content />
        </div>

        <!-- Especificações técnicas -->
        <div class="mt-16 rounded-2xl border border-primary-100 bg-white p-10 shadow-sm">
          <h2 class="mb-8 font-display text-2xl font-bold text-text">Como funciona o atendimento</h2>
          <div class="grid gap-8 md:grid-cols-3">
            <div class="space-y-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-50 font-display text-xl font-bold text-primary">1</div>
              <h3 class="font-display text-lg font-bold text-text">Contato</h3>
              <p class="text-muted">Você nos chama pelo WhatsApp ou telefone e descreve o problema.</p>
            </div>
            <div class="space-y-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-50 font-display text-xl font-bold text-primary">2</div>
              <h3 class="font-display text-lg font-bold text-text">Diagnóstico</h3>
              <p class="text-muted">Nossa equipe avalia a causa do entupimento e apresenta o orçamento.</p>
            </div>
            <div class="space-y-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-50 font-display text-xl font-bold text-primary">3</div>
              <h3 class="font-display text-lg font-bold text-text">Execução</h3>
              <p class="text-muted">Resolvemos o problema com equipamento adequado e limpamos o local.</p>
            </div>
          </div>
        </div>

        <!-- Benefícios -->
        <div class="mt-16 rounded-2xl bg-secondary-50 p-10">
          <h2 class="mb-8 font-display text-2xl font-bold text-text">
            Por que contratar a Desentupidora Rio de Janeiro para {shortName.toLowerCase()}?
          </h2>
          <ul class="grid gap-4 md:grid-cols-2">
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-primary-700">✓</span>
              Atendimento 24h, inclusive feriados.
            </li>
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-primary-700">✓</span>
              Equipes espalhadas por todas as zonas do Rio de Janeiro.
            </li>
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-primary-700">✓</span>
              Orçamento grátis e sem compromisso.
            </li>
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-primary-700">✓</span>
              Equipamento profissional para cada tipo de entupimento.
            </li>
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-primary-700">✓</span>
              Garantia no serviço e reajuste sem custo se necessário.
            </li>
            <li class="flex items-start gap-3 text-muted">
              <span class="mt-1 text-primary-700">✓</span>
              Local limpo e organizado ao final do trabalho.
            </li>
          </ul>
        </div>

        <!-- CTA de fechamento -->
        <div class="mt-16 rounded-3xl bg-dark p-12 text-center text-white md:p-16">
          <h2 class="mb-4 font-display text-3xl font-bold md:text-4xl">
            Precisa de {serviceName.toLowerCase()}?
          </h2>
          <p class="mx-auto mb-8 max-w-2xl text-lg text-slate-300">
            Fale conosco agora e receba atendimento 24h no Rio de Janeiro. Orçamento grátis,
            chegada rápida e garantia real no serviço.
          </p>
          <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
            <Button href={whatsappLink()} variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
              Chamar no WhatsApp
            </Button>
            <Button href={phoneLink()} variant="outline" size="lg">
              Ligar: {SITE_CONFIG.phone.replace('+55', '').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3')}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </article>
</Layout>
