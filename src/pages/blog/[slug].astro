---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SchemaBreadcrumbs from '../../components/seo/SchemaBreadcrumbs.astro';
import SchemaArticle from '../../components/seo/SchemaArticle.astro';
import { SITE_CONFIG, whatsappLink, phoneLink } from '../../data/config.ts';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '').replace(/\//g, '-') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const modDate = post.data.updatedDate || new Date();

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const slug = Astro.params.slug;
const ogImageUrl = post.data.ogImage ? `${SITE_CONFIG.domain}${post.data.ogImage}` : undefined;
const breadcrumbs = [
  { name: 'Início', url: '/' },
  { name: 'Blog', url: '/blog/' },
  { name: post.data.title, url: `/blog/${slug}/`, current: true },
];
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={ogImageUrl}
  type="article"
  pubDate={post.data.pubDate}
  modDate={modDate}>

  <SchemaBreadcrumbs items={breadcrumbs} />
  <SchemaArticle
    title={post.data.title}
    description={post.data.description}
    url={`${SITE_CONFIG.domain}/blog/${slug}/`}
    image={ogImageUrl}
    pubDate={post.data.pubDate}
    modDate={modDate}
  />
  <Breadcrumbs items={breadcrumbs} />

  <article class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="grid gap-12 lg:grid-cols-3">
        <!-- Conteúdo principal -->
        <div class="lg:col-span-2">
          <a href="/blog/" class="mb-8 inline-flex items-center text-sm font-semibold text-alert-700 hover:text-alert-900">
            <svg class="mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 12H5M12 19l-7-7 7-7" />
            </svg>
            Voltar para o blog
          </a>

          <span class="mb-3 block text-sm font-bold tracking-wider text-alert-700 uppercase">
            Publicado em {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
            <span class="mx-2 text-muted">•</span>
            Atualizado em {new Date().toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
          </span>
          <h1 class="mb-6 font-display text-page font-extrabold leading-tight break-safe text-text md:text-5xl">
            {post.data.title}
          </h1>
          <p class="mb-12 text-xl leading-relaxed text-muted">
            {post.data.description}
          </p>

          <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-text prose-a:text-alert-700 hover:prose-a:text-alert-900">
            <Content />
          </div>

          <div class="mt-12 border-2 border-steel bg-concrete p-8">
            <p class="text-sm text-muted">
              <strong class="text-ink">Sobre o conteúdo:</strong> Este artigo foi produzido pela equipe técnica da
              Desentupidora Rio de Janeiro com base em anos de experiência em atendimento de
              emergências de entupimento na cidade. As informações são atualizadas regularmente.
            </p>
          </div>

          <div class="mt-8 border-4 border-white bg-ink p-10 text-center text-white shadow-[12px_12px_0px_0px_rgba(217,92,30,1)]">
            <h2 class="mb-4 font-display text-2xl font-bold">Precisa de uma desentupidora no Rio?</h2>
            <p class="mb-8 text-white/70">Atendimento 24h por WhatsApp. Orçamento grátis e chegada rápida.</p>
            <Button href={whatsappLink()} variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
              Chamar no WhatsApp
            </Button>
          </div>
        </div>

        <!-- Barra lateral -->
        <aside class="space-y-8">
          <div class="border-2 border-white bg-ink p-8 text-white">
            <h2 class="mb-4 font-display text-xl font-bold">Orçamento grátis</h2>
            <p class="mb-6 text-sm leading-relaxed text-white/80">
              Descreva seu problema que enviamos uma equipe para avaliar e orçar sem compromisso.
            </p>
            <Button href={whatsappLink()} variant="accent" size="md" target="_blank" rel="noopener noreferrer" class="w-full">
              Chamar no WhatsApp
            </Button>
            <a
              href={phoneLink()}
              class="mt-3 block w-full border-2 border-white p-3 text-center text-sm font-bold text-white hover:bg-white/10 transition-colors"
            >
              {SITE_CONFIG.phone.replace('+55', '').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3')}
            </a>
          </div>

          <div class="border-2 border-steel bg-white p-8 shadow-[6px_6px_0px_0px_rgba(225,231,236,1)]">
            <h2 class="mb-6 font-display text-xl font-bold text-text">Serviços populares</h2>
            <ul class="space-y-3">
              <li><a href="/servicos/desentupimento-de-esgoto/" class="text-muted hover:text-alert">Desentupimento de esgoto</a></li>
              <li><a href="/servicos/desentupimento-de-cano/" class="text-muted hover:text-alert">Desentupimento de cano</a></li>
              <li><a href="/servicos/desentupimento-de-pia/" class="text-muted hover:text-alert">Desentupimento de pia</a></li>
              <li><a href="/servicos/desentupimento-de-vaso-sanitario/" class="text-muted hover:text-alert">Desentupimento de vaso sanitário</a></li>
              <li><a href="/servicos/limpeza-de-fossa-e-caixa-de-gordura/" class="text-muted hover:text-alert">Limpeza de fossa e caixa de gordura</a></li>
            </ul>
          </div>

          {relatedPosts.length > 0 && (
            <div class="border-2 border-steel bg-white p-8 shadow-[6px_6px_0px_0px_rgba(225,231,236,1)]">
              <h2 class="mb-6 font-display text-xl font-bold text-text">Outras dicas</h2>
              <ul class="space-y-5">
                {relatedPosts.map((related) => (
                  <li>
                    <a
                      href={`/blog/${related.id.replace(/\.md$/, '').replace(/\//g, '-')}/`}
                      class="group block"
                    >
                      <span class="block text-xs text-muted">
                        {related.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
                      </span>
                      <span class="block font-semibold text-text group-hover:text-alert">
                        {related.data.title}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      </div>
    </div>
  </article>
</Layout>
