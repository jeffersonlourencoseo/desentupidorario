---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Button from '../components/Button.astro';

const allServices = await getCollection('servicos');
const services = allServices.sort((a, b) => a.data.order - b.data.order).slice(0, 6);

const differentials = [
  { title: 'Atendimento 24h', description: 'Emergência em entupimentos não espera. Atendemos todos os dias, inclusive feriados.', icon: '⏰' },
  { title: 'Toda a cidade do RJ', description: 'Desentupidora que chega rápido em qualquer zona do Rio de Janeiro.', icon: '📍' },
  { title: 'Orçamento grátis', description: 'Avaliação honesta e sem compromisso antes de qualquer serviço.', icon: '📝' },
  { title: 'Garantia no serviço', description: 'Você só paga quando o entupimento estiver realmente resolvido.', icon: '🛡️' },
];

const testimonials = [
  { name: 'Carlos Mendes', location: 'Copacabana, RJ', text: 'O vaso sanitário entupiu às 23h e em 40 minutos a equipe já estava aqui. Serviço limpo, rápido e sem surpresa no preço.' },
  { name: 'Fernanda Lima', location: 'Tijuca, RJ', text: 'Já tinha chamado outra desentupidora que não resolveu. A Desentupidora RJ fez o serviço direto e ainda explicou como evitar no futuro.' },
  { name: 'Restaurante Sabor Carioca', location: 'Centro, RJ', text: 'Limpeza periódica da caixa de gordura com pontualidade. É tranquilo saber que podemos contar com eles.' },
];
---

<Layout>
  <Hero />

  <!-- Diferenciais -->
  <section class="border-b border-primary-100 bg-light py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 max-w-2xl text-center mx-auto">
        <span class="mb-3 block text-sm font-bold tracking-wider text-primary-700 uppercase">Por que nos escolher</span>
        <h2 class="font-display text-3xl font-bold text-text md:text-4xl">
          Rapidez e garantia em cada atendimento
        </h2>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {differentials.map((item) => (
          <div class="rounded-2xl bg-white p-10 shadow-sm text-center">
            <div class="mb-4 text-4xl" aria-hidden="true">{item.icon}</div>
            <h3 class="mb-3 font-display text-lg font-bold text-text">{item.title}</h3>
            <p class="text-sm leading-relaxed text-muted">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sobre Nós (resumo) -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div class="space-y-6">
          <span class="text-sm font-bold tracking-wider text-primary-700 uppercase">Sobre nós</span>
          <h2 class="font-display text-3xl font-bold text-text md:text-4xl">
            A desentupidora que o Rio de Janeiro confia
          </h2>
          <p class="text-lg leading-relaxed text-muted">
            A Desentupidora Rio de Janeiro une equipe treinada, equipamento moderno e
            atendimento humano. Sabemos que entupimento não avisa: por isso estamos
            prontos 24 horas para chegar até você, seja qual for a região da cidade.
          </p>
          <p class="text-lg leading-relaxed text-muted">
            Trabalhamos com desentupimento de esgoto, canos, pias, ralos, vasos sanitários,
            além de limpeza de fossa e caixa de gordura. Tudo com orçamento grátis,
            chegada rápida e garantia real no serviço.
          </p>
          <Button href="/sobre/" variant="primary" size="lg">
            Conheça nossa história
          </Button>
        </div>

        <div class="rounded-3xl bg-primary-50 p-12">
          <div class="grid grid-cols-2 gap-8 text-center">
            <div>
              <div class="font-display text-5xl font-extrabold text-primary">24h</div>
              <div class="mt-2 text-sm font-semibold text-muted uppercase tracking-wider">Atendimento</div>
            </div>
            <div>
              <div class="font-display text-5xl font-extrabold text-primary">RJ</div>
              <div class="mt-2 text-sm font-semibold text-muted uppercase tracking-wider">Toda cidade</div>
            </div>
            <div>
              <div class="font-display text-5xl font-extrabold text-accent">0</div>
              <div class="mt-2 text-sm font-semibold text-muted uppercase tracking-wider">Custo de visita*</div>
            </div>
            <div>
              <div class="font-display text-5xl font-extrabold text-primary">100%</div>
              <div class="mt-2 text-sm font-semibold text-muted uppercase tracking-wider">Garantia</div>
            </div>
          </div>
          <p class="mt-8 text-center text-xs text-muted">*Orçamento grátis. Valor cobrado apenas se o serviço for executado.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Serviços -->
  <section id="servicos" class="border-y border-primary-100 bg-primary-50 py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div class="max-w-2xl">
          <span class="mb-3 block text-sm font-bold tracking-wider text-primary-700 uppercase">Nossos Serviços</span>
          <h2 class="font-display text-3xl font-bold text-text md:text-4xl">
            Desentupimento completo no Rio de Janeiro
          </h2>
          <p class="mt-4 text-lg text-muted">
            Do ralo entupido à fossa cheia, temos a solução certa para cada tipo de entupimento.
          </p>
        </div>
        <Button href="/servicos/" variant="primary" size="md">
          Ver todos os serviços
        </Button>
      </div>

      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <a href={`/servicos/${service.id.replace(/\.md$/, '').replace(/\//g, '-')}/`} class="block group">
            <ServiceCard
              title={service.data.title.replace(' no Rio de Janeiro', '')}
              description={service.data.description}
              icon={service.data.icon || '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>'}
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Depoimentos -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 max-w-2xl text-center mx-auto">
        <span class="mb-3 block text-sm font-bold tracking-wider text-primary-700 uppercase">Depoimentos</span>
        <h2 class="font-display text-3xl font-bold text-text md:text-4xl">
          O que dizem nossos clientes no Rio de Janeiro
        </h2>
      </div>

      <div class="grid gap-10 md:grid-cols-3">
        {testimonials.map((item) => (
          <article class="rounded-2xl border border-primary-100 bg-white p-10 shadow-sm transition-all hover:-translate-y-1 hover:border-secondary/30 hover:shadow-lg">
            <div class="mb-6 flex gap-1 text-accent" aria-hidden="true">
              {'★★★★★'.split('').map((star) => (
                <span>{star}</span>
              ))}
            </div>
            <blockquote class="mb-6 leading-relaxed text-muted">
              "{item.text}"
            </blockquote>
            <footer>
              <div class="font-display font-bold text-text">{item.name}</div>
              <div class="text-sm text-muted">{item.location}</div>
            </footer>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Chamada de Contato -->
  <section id="contato" class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="rounded-3xl bg-dark p-12 text-center text-white md:p-20">
        <h2 class="font-display text-3xl font-bold md:text-5xl">
          Entupimento agora? Chame a gente.
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-300">
          Atendimento 24h em toda a cidade do Rio de Janeiro. Orçamento grátis,
          chegada rápida e garantia no serviço.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <Button href="whatsappLink()" variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
            Conversar no WhatsApp
          </Button>
          <Button href="phoneLink()" variant="outline" size="lg">
            Ligar agora: (21) 99775-1577
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>
