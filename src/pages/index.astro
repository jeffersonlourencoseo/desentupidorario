---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Button from '../components/Button.astro';
import { SITE_CONFIG, whatsappLink, phoneLink } from '../data/config.ts';

const allServices = await getCollection('servicos');
const services = allServices.sort((a, b) => a.data.order - b.data.order).slice(0, 6);

const differentials = [
  {
    title: 'Atendimento 24h',
    description: 'Emergência em entupimentos não espera. Atendemos todos os dias, inclusive feriados.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  },
  {
    title: 'Toda a cidade do RJ',
    description: 'Desentupidora que chega rápido em qualquer zona do Rio de Janeiro.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>',
  },
  {
    title: 'Orçamento grátis',
    description: 'Avaliação honesta e sem compromisso antes de qualquer serviço.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
  },
  {
    title: 'Garantia no serviço',
    description: 'Você só paga quando o entupimento estiver realmente resolvido.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>',
  },
];

const testimonials = [
  { name: 'Carlos Mendes', location: 'Copacabana, RJ', text: 'O vaso sanitário entupiu às 23h e em 40 minutos a equipe já estava aqui. Serviço limpo, rápido e sem surpresa no preço.' },
  { name: 'Fernanda Lima', location: 'Tijuca, RJ', text: 'Já tinha chamado outra desentupidora que não resolveu. A Desentupidora RJ fez o serviço direto e ainda explicou como evitar no futuro.' },
  { name: 'Restaurante Sabor Carioca', location: 'Centro, RJ', text: 'Limpeza periódica da caixa de gordura com pontualidade. É tranquilo saber que podemos contar com eles.' },
];
---

<Layout>
  <Hero />

  <!-- Diferenciais -->
  <section class="border-b-4 border-steel bg-concrete py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-12">
      <div class="mb-12 max-w-2xl text-center mx-auto md:mb-16">
        <span class="mb-3 inline-block border border-alert-600 bg-alert-700 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">Por que nos escolher</span>
        <h2 class="font-display text-section uppercase leading-[0.92] tracking-wide break-safe text-ink sm:text-5xl md:text-6xl">
          Desentupidora 24h no Rio de Janeiro
        </h2>
        <p class="mt-4 text-base text-muted sm:text-lg">
          Atendimento de emergência em desentupimento de esgoto, pia, ralo, vaso sanitário, fossa e caixa de gordura.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 sm:gap-6">
        {differentials.map((item) => (
          <div class="border-2 border-ink bg-white p-5 shadow-[3px_3px_0px_0px_rgba(10,22,40,1)] sm:p-8">
            <div class="mb-4 flex h-12 w-12 items-center justify-center border-2 border-ink bg-signal text-ink sm:mb-5 sm:h-14 sm:w-14" aria-hidden="true" set:html={item.svg} />
            <h3 class="mb-2 font-display text-lg uppercase tracking-wide text-ink sm:mb-3 sm:text-xl">{item.title}</h3>
            <p class="text-sm leading-relaxed text-muted">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sobre Nós (resumo) -->
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-12">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div class="space-y-5">
          <span class="inline-block border border-alert-600 bg-alert-700 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">Sobre nós</span>
          <h2 class="font-display text-section uppercase leading-[0.92] tracking-wide break-safe text-ink sm:text-5xl md:text-6xl">
            A desentupidora que o Rio de Janeiro confia
          </h2>
          <p class="text-base leading-relaxed text-muted sm:text-lg">
            A Desentupidora Rio de Janeiro une equipe treinada, equipamento moderno e
            atendimento humano. Sabemos que entupimento não avisa: por isso estamos
            prontos 24 horas para chegar até você, seja qual for a região da cidade.
          </p>
          <p class="text-base leading-relaxed text-muted sm:text-lg">
            Oferecemos desentupimento de esgoto, cano, pia, ralo, vaso sanitário,
            limpeza de fossa e caixa de gordura com preço justo e orçamento grátis.
            Atuamos em todas as regiões: Zona Norte, Zona Sul, Zona Oeste, Centro e
            Barra da Tijuca.
          </p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <Button href="/quem-somos/" variant="outline-dark" size="lg">
              Conheça nossa história
            </Button>
            <Button href="/perguntas-frequentes/" variant="outline-dark" size="lg">
              Tire suas dúvidas
            </Button>
          </div>
        </div>

        <div class="border-4 border-ink bg-signal p-6 shadow-[6px_6px_0px_0px_rgba(255,107,0,1)] sm:p-10 md:p-12">
          <div class="grid grid-cols-2 gap-6 text-center sm:gap-8">
            <div>
              <div class="font-display text-5xl uppercase leading-none text-ink sm:text-6xl">24h</div>
              <div class="mt-2 text-xs font-bold uppercase tracking-wider text-ink">Atendimento</div>
            </div>
            <div>
              <div class="font-display text-5xl uppercase leading-none text-ink sm:text-6xl">RJ</div>
              <div class="mt-2 text-xs font-bold uppercase tracking-wider text-ink">Toda cidade</div>
            </div>
            <div>
              <div class="font-display text-5xl uppercase leading-none text-alert-700 sm:text-6xl">0</div>
              <div class="mt-2 text-xs font-bold uppercase tracking-wider text-ink">Custo de visita*</div>
            </div>
            <div>
              <div class="font-display text-5xl uppercase leading-none text-ink sm:text-6xl">100%</div>
              <div class="mt-2 text-xs font-bold uppercase tracking-wider text-ink">Garantia</div>
            </div>
          </div>
          <p class="mt-6 text-center text-xs font-bold uppercase tracking-wide text-ink sm:mt-8">*Orçamento e visita de avaliação sem custo. Valor cobrado apenas se executado.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Serviços -->
  <section id="servicos" class="border-y-4 border-steel bg-concrete py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-12">
      <div class="mb-12 flex flex-col justify-between gap-5 md:flex-row md:items-end md:mb-16">
        <div class="max-w-2xl">
          <span class="mb-3 inline-block border border-alert-600 bg-alert-700 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">Nossos Serviços</span>
          <h2 class="font-display text-section uppercase leading-[0.92] tracking-wide break-safe text-ink sm:text-5xl md:text-6xl">
            Serviços de desentupimento no Rio
          </h2>
          <p class="mt-4 text-base text-muted sm:text-lg">
            Do ralo entupido à fossa cheia, temos a solução certa para cada tipo de entupimento.
          </p>
        </div>
        <Button href="/servicos/" variant="outline-dark" size="md">
          Ver todos os serviços
        </Button>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 sm:gap-6">
        {services.map((service) => (
          <a href={`/servicos/${service.id.replace(/\.md$/, '').replace(/\//g, '-')}/`} class="block group">
            <ServiceCard
              title={service.data.title.replace(' no Rio de Janeiro', '')}
              description={service.data.description}
              icon={service.data.icon || '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>'}
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Depoimentos -->
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-12">
      <div class="mb-12 max-w-2xl text-center mx-auto md:mb-16">
        <span class="mb-3 inline-block border border-alert-600 bg-alert-700 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">Depoimentos</span>
        <h2 class="font-display text-section uppercase leading-[0.92] tracking-wide break-safe text-ink sm:text-5xl md:text-6xl">
          Quem já chamou nossa desentupidora
        </h2>
      </div>

      <div class="grid gap-4 md:grid-cols-3 sm:gap-6">
        {testimonials.map((item) => (
          <article class="border-2 border-ink bg-white p-6 shadow-[3px_3px_0px_0px_rgba(255,107,0,1)] sm:p-8">
            <div class="mb-4 flex gap-1 text-signal sm:mb-5" aria-hidden="true">
              {'★★★★★'.split('').map((star) => (
                <span class="text-alert">{star}</span>
              ))}
            </div>
            <blockquote class="mb-5 text-sm leading-relaxed text-muted sm:mb-6 sm:text-base">
              "{item.text}"
            </blockquote>
            <footer class="border-t-2 border-steel pt-4 sm:pt-5">
              <div class="font-display text-base uppercase tracking-wide text-ink sm:text-lg">{item.name}</div>
              <div class="text-xs font-bold uppercase tracking-wider text-muted">{item.location}</div>
            </footer>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Chamada de Contato -->
  <section id="contato" class="py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-12">
      <div class="relative border-4 border-white bg-ink p-8 text-center text-white shadow-[6px_6px_0px_0px_rgba(255,107,0,1)] sm:p-12 md:p-20">
        <h2 class="font-display text-section uppercase leading-[0.92] tracking-wide break-safe sm:text-5xl md:text-6xl lg:text-7xl">
          Precisa de uma desentupidora urgente?
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-base text-white/80 sm:mt-6 sm:text-lg">
          Atendimento de desentupimento 24h em toda a cidade do Rio. Orçamento grátis,
          chegada rápida e garantia no serviço.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4 md:mt-10">
          <Button href={whatsappLink()} variant="secondary" size="lg" target="_blank" rel="noopener noreferrer">
            Chamar no WhatsApp
          </Button>
          <Button href={phoneLink()} variant="outline" size="lg">
            Ligar: {SITE_CONFIG.phone.replace('+55', '').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3')}
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>
