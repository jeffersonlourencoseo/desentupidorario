---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SchemaBreadcrumbs from '../components/seo/SchemaBreadcrumbs.astro';
import { whatsappLink, SITE_CONFIG } from '../data/config.ts';

const stats = [
  { value: '+5', label: 'Anos de experiência' },
  { value: '24h', label: 'Atendimento todos os dias' },
  { value: '100%', label: 'Foco no cliente' },
  { value: 'RJ', label: 'Toda a cidade' },
];

const timeline = [
  {
    year: '2019',
    title: 'O início',
    text: 'Começamos atendendo bairros da Zona Norte do Rio com uma equipe pequena, mas com um compromisso grande: resolver de verdade e não criar surpresas no preço.',
  },
  {
    year: '2021',
    title: 'Expansão',
    text: 'A demanda cresceu e expandimos nossa operação para atender todas as zonas da cidade, montando equipes próprias e investindo em equipamento industrial.',
  },
  {
    year: '2024',
    title: 'Padrão 24h',
    text: 'Consolidamos o atendimento 24 horas, com equipes de prontidão para emergências de esgoto, fossa e caixa de gordura em qualquer região do Rio.',
  },
  {
    year: '2026',
    title: 'Referência',
    text: 'Hoje somos a desentupidora que o Rio de Janeiro confia para resolver entupimentos com rapidez, limpeza e garantia real no serviço.',
  },
];

const values = [
  {
    title: 'Honestidade',
    text: 'Orçamento claro antes de começar. Você só paga quando o serviço é executado.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>',
  },
  {
    title: 'Rapidez',
    text: 'Entupimento não avisa. Por isso chegamos rápido, em qualquer horário e em qualquer bairro do Rio.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  },
  {
    title: 'Limpeza',
    text: 'Usamos equipamento adequado e protegemos o local. Ao final, deixamos tudo limpo e organizado.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>',
  },
  {
    title: 'Garantia',
    text: 'Se o problema persistir, voltamos sem custo extra. Nossa palavra é compromisso de verdade.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>',
  },
];

const team = [
  { role: 'Atendimento', name: 'Jefferson', text: 'Recebe sua ligação ou mensagem, entende a urgência e organiza o deslocamento da equipe mais próxima.' },
  { role: 'Técnicos', name: 'Equipe técnica', text: 'Profissionais experientes com equipamento próprio para desentupimento, limpeza de fossa e caixa de gordura.' },
  { role: 'Pós-atendimento', name: 'Suporte', text: 'Acompanha o resultado para garantir que o problema foi resolvido e que você ficou satisfeito.' },
];

const credentials = [
  { label: 'Atuação', value: '+5 anos no Rio de Janeiro' },
  { label: 'Atendimento', value: '24 horas, todos os dias' },
  { label: 'Cobertura', value: 'Toda a cidade do Rio' },
  { label: 'Garantia', value: 'Serviço com compromisso real' },
];

const breadcrumbs = [
  { name: 'Início', url: '/' },
  { name: 'Quem Somos', url: '/quem-somos/', current: true },
];
---

<Layout
  title="Quem Somos"
  description="Conheça a Desentupidora Rio de Janeiro. Anos de experiência, atendimento 24h em toda a cidade e compromisso real com cada cliente.">

  <SchemaBreadcrumbs items={breadcrumbs} />
  <Breadcrumbs items={breadcrumbs} />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-ink py-24 text-white md:py-32">
    <div class="absolute inset-0 opacity-10" aria-hidden="true">
      <svg class="h-full w-full" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid-quem" width="60" height="60" patternUnits="userSpaceOnUse">
            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="currentColor" stroke-width="1" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid-quem)" />
      </svg>
    </div>
    <div class="absolute -right-20 top-0 h-[140%] w-32 -rotate-12 bg-alert/80 md:w-48" aria-hidden="true"></div>

    <div class="container relative mx-auto px-6 lg:px-12">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div class="max-w-xl">
          <span class="mb-4 inline-flex items-center gap-3 border-2 border-signal bg-signal px-4 py-2 text-sm font-bold uppercase tracking-wide text-ink">
            Quem Somos
          </span>
          <h1 class="font-display text-hero uppercase leading-[0.9] tracking-wide break-safe md:text-8xl">
            Quem{' '}
            <span class="block text-signal">Somos</span>
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-white/80 md:text-xl">
            Somos uma empresa de desentupimento do Rio de Janeiro com mais de 5 anos de atuação.
            Atendemos residências, comércios e condomínios com gente de verdade, equipamento de verdade e garantia de verdade.
          </p>
          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <Button href={whatsappLink()} variant="secondary" size="lg" target="_blank" rel="noopener noreferrer">
              Chamar no WhatsApp
            </Button>
            <Button href="/servicos/" variant="outline" size="lg">
              Ver serviços
            </Button>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-4 border-2 border-alert/30"></div>
          <div class="relative border-4 border-white bg-white p-10 text-ink shadow-[12px_12px_0px_0px_rgba(255,107,0,1)] md:p-14">
            <blockquote class="font-display text-2xl uppercase leading-snug tracking-wide md:text-3xl">
              "Chegar rápido, resolver de verdade e deixar o local limpo."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="flex h-12 w-12 items-center justify-center border-2 border-ink bg-ink font-display text-xl text-white">DR</div>
              <div>
                <div class="font-bold text-ink">Equipe Desentupidora RJ</div>
                <div class="text-sm font-bold uppercase tracking-wider text-muted">Rio de Janeiro</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Estatísticas -->
  <section class="border-y-4 border-steel bg-signal py-16">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        {stats.map((item) => (
          <div class="text-center">
            <div class="font-display text-5xl uppercase leading-none text-ink md:text-6xl">{item.value}</div>
            <div class="mt-2 text-sm font-bold uppercase tracking-wider text-ink">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- História -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 max-w-3xl">
        <span class="mb-4 inline-block border-2 border-alert-600 bg-alert-700 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">Nossa história</span>
        <h2 class="font-display text-section uppercase leading-[0.9] tracking-wide break-safe text-ink md:text-6xl">
          De pequena equipe a referência
        </h2>
      </div>

      <div class="relative">
        <div class="absolute left-4 top-0 bottom-0 w-1 bg-steel md:left-1/2 md:-ml-0.5"></div>
        {timeline.map((item, index) => (
          <div class={`relative mb-14 md:grid md:grid-cols-2 md:gap-12 ${index % 2 === 0 ? '' : 'md:text-right'}`}>
            <div class={`pl-14 md:pl-0 ${index % 2 === 0 ? 'md:pr-12' : 'md:order-2 md:pl-12'}`}>
              <span class="absolute left-0 top-0 flex h-9 w-9 items-center justify-center border-2 border-ink bg-alert text-sm font-bold text-white md:left-1/2 md:-ml-4.5">
                {index + 1}
              </span>
              <div class="inline-block border-2 border-ink bg-ink px-3 py-1 text-sm font-bold uppercase tracking-wider text-white">
                {item.year}
              </div>
              <h3 class="mt-3 font-display text-2xl uppercase tracking-wide text-ink">{item.title}</h3>
              <p class="mt-2 leading-relaxed text-muted">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Valores -->
  <section class="border-y-4 border-steel bg-concrete py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 max-w-2xl text-center mx-auto">
        <span class="mb-4 inline-block border-2 border-alert-600 bg-alert-700 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">O que nos move</span>
        <h2 class="font-display text-section uppercase leading-[0.9] tracking-wide break-safe text-ink md:text-6xl">Nossos valores</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {values.map((item) => (
          <div class="border-2 border-ink bg-white p-8 shadow-[6px_6px_0px_0px_rgba(10,22,40,1)]">
            <div class="mb-5 flex h-14 w-14 items-center justify-center border-2 border-ink bg-signal text-ink" aria-hidden="true" set:html={item.svg} />
            <h3 class="mb-3 font-display text-xl uppercase tracking-wide text-ink">{item.title}</h3>
            <p class="text-sm leading-relaxed text-muted">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Credibilidade -->
  <section class="border-y-4 border-steel bg-concrete py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 max-w-2xl">
        <span class="mb-4 inline-block border-2 border-alert-600 bg-alert-700 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">Credibilidade</span>
        <h2 class="font-display text-section uppercase leading-[0.9] tracking-wide break-safe text-ink md:text-6xl">Por que confiar na gente</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {credentials.map((item) => (
          <div class="border-2 border-ink bg-white p-8 shadow-[6px_6px_0px_0px_rgba(10,22,40,1)]">
            <div class="mb-2 text-xs font-bold uppercase tracking-wider text-muted">{item.label}</div>
            <div class="font-display text-2xl uppercase tracking-wide text-ink">{item.value}</div>
          </div>
        ))}
      </div>

      <div class="mt-12 max-w-3xl space-y-4 text-muted">
        <p>
          A Desentupidora Rio de Janeiro trabalha com equipamento próprio e equipe treinada para cada tipo de serviço:
          desentupimento de esgoto, cano, pia, ralo, vaso sanitário, limpeza de fossa e caixa de gordura.
        </p>
        <p>
          Nosso endereço comercial fica em {SITE_CONFIG.fullAddress}. Você pode nos encontrar pelo telefone
          {SITE_CONFIG.phone.replace('+55', '').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3')} ou pelo e-mail
          {SITE_CONFIG.email}. Atendemos emergências 24h em toda a cidade.
        </p>
      </div>
    </div>
  </section>

  <!-- Equipe -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 max-w-2xl">
        <span class="mb-4 inline-block border-2 border-alert-600 bg-alert-700 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">Nossa equipe</span>
        <h2 class="font-display text-section uppercase leading-[0.9] tracking-wide break-safe text-ink md:text-6xl">Quem cuida do seu atendimento</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {team.map((item) => (
          <div class="border-2 border-ink bg-white p-8 shadow-[6px_6px_0px_0px_rgba(255,107,0,1)]">
            <div class="mb-4 inline-flex h-14 w-14 items-center justify-center border-2 border-ink bg-signal font-display text-2xl text-ink">{item.name.charAt(0)}</div>
            <h3 class="mb-1 font-display text-xl uppercase tracking-wide text-ink">{item.name}</h3>
            <div class="mb-3 text-sm font-bold uppercase tracking-wider text-muted">{item.role}</div>
            <p class="leading-relaxed text-muted">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="pb-24 md:pb-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="relative border-4 border-white bg-ink p-12 text-center text-white shadow-[12px_12px_0px_0px_rgba(255,107,0,1)] md:p-20">
        <h2 class="font-display text-section uppercase leading-[0.9] tracking-wide break-safe md:text-7xl">
          Chame quem entende
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-white/80">
          Atendimento 24h em toda a cidade do Rio de Janeiro. Orçamento grátis, chegada rápida e garantia no serviço.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <Button href={whatsappLink()} variant="secondary" size="lg" target="_blank" rel="noopener noreferrer">
            Chamar no WhatsApp
          </Button>
          <Button href="/contato/" variant="outline" size="lg">
            Falar por telefone
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>
