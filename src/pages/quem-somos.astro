---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { SITE_CONFIG, whatsappLink } from '../data/config.ts';

const stats = [
  { value: '+5', label: 'Anos de experiência' },
  { value: '24h', label: 'Atendimento todos os dias' },
  { value: '100%', label: 'Foco no cliente' },
  { value: 'RJ', label: 'Toda a cidade' },
];

const timeline = [
  {
    year: '2019',
    title: 'O início',
    text: 'Começamos atendendo bairros da Zona Norte do Rio com uma equipe pequena, mas com um compromisso grande: resolver de verdade e não criar surpresas no preço.',
  },
  {
    year: '2021',
    title: 'Expansão',
    text: 'A demanda cresceu e expandimos nossa operação para atender todas as zonas da cidade, montando equipes próprias e investindo em equipamento industrial.',
  },
  {
    year: '2024',
    title: 'Padrão 24h',
    text: 'Consolidamos o atendimento 24 horas, com equipes de prontidão para emergências de esgoto, fossa e caixa de gordura em qualquer região do Rio.',
  },
  {
    year: '2026',
    title: 'Referência',
    text: 'Hoje somos a desentupidora que o Rio de Janeiro confia para resolver entupimentos com rapidez, limpeza e garantia real no serviço.',
  },
];

const values = [
  {
    title: 'Honestidade',
    text: 'Orçamento claro antes de começar. Você só paga quando o serviço é executado.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>',
  },
  {
    title: 'Rapidez',
    text: 'Entupimento não avisa. Por isso chegamos rápido, em qualquer horário e em qualquer bairro do Rio.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  },
  {
    title: 'Limpeza',
    text: 'Usamos equipamento adequado e protegemos o local. Ao final, deixamos tudo limpo e organizado.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>',
  },
  {
    title: 'Garantia',
    text: 'Se o problema persistir, voltamos sem custo extra. Nossa palavra é compromisso de verdade.',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>',
  },
];

const team = [
  { role: 'Atendimento', text: 'Recebe sua ligação ou mensagem, entende a urgência e organiza o deslocamento da equipe mais próxima.' },
  { role: 'Técnicos', text: 'Profissionais experientes com equipamento próprio para desentupimento, limpeza de fossa e caixa de gordura.' },
  { role: 'Pós-atendimento', text: 'Acompanha o resultado para garantir que o problema foi resolvido e que você ficou satisfeito.' },
];
---

<Layout
  title="Quem Somos | Desentupidora Rio de Janeiro"
  description="Conheça a Desentupidora Rio de Janeiro. Anos de experiência, atendimento 24h em toda a cidade e compromisso real com cada cliente.">

  <!-- Hero assimétrico -->
  <section class="relative overflow-hidden bg-primary py-24 text-white md:py-32">
    <div class="absolute -right-20 -top-20 h-96 w-96 rounded-full bg-white/5 blur-3xl" aria-hidden="true"></div>
    <div class="absolute -left-20 bottom-0 h-72 w-72 rounded-full bg-secondary/20 blur-3xl" aria-hidden="true"></div>

    <div class="container relative mx-auto px-6 lg:px-12">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div class="max-w-xl">
          <span class="mb-4 inline-block rounded-full bg-white/10 px-4 py-2 text-sm font-semibold tracking-wide backdrop-blur-sm">
            Quem Somos
          </span>
          <h1 class="font-display text-4xl font-extrabold leading-tight md:text-6xl">
            A desentupidora que o Rio de Janeiro confia
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-primary-50 md:text-xl">
            Desentupimento com gente de verdade, equipamento de verdade e garantia de verdade.
            Atuamos 24 horas por dia em toda a cidade do Rio de Janeiro.
          </p>
          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <Button href={whatsappLink()} variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
              Chamar no WhatsApp
            </Button>
            <Button href="/servicos/" variant="outline" size="lg">
              Ver serviços
            </Button>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 -rotate-3 rounded-3xl bg-accent/30"></div>
          <div class="relative rounded-3xl bg-white p-10 text-text shadow-2xl md:p-14">
            <blockquote class="font-display text-2xl font-bold leading-snug md:text-3xl">
              "Chegar rápido, resolver de verdade e deixar o local limpo. Esse é o nosso jeito."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary font-display font-bold text-white">
                DR
              </div>
              <div>
                <div class="font-bold text-text">Equipe Desentupidora RJ</div>
                <div class="text-sm text-muted">Rio de Janeiro</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Estatísticas -->
  <section class="border-y border-primary-100 bg-light py-16">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        {stats.map((item) => (
          <div class="text-center">
            <div class="font-display text-5xl font-extrabold text-primary md:text-6xl">{item.value}</div>
            <div class="mt-2 text-sm font-semibold uppercase tracking-wider text-muted">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- História -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 max-w-3xl">
        <span class="mb-3 block text-sm font-bold tracking-wider text-primary-700 uppercase">Nossa história</span>
        <h2 class="font-display text-3xl font-bold text-text md:text-4xl">
          De pequena equipe a referência no Rio
        </h2>
        <p class="mt-4 text-lg text-muted">
          Nascemos da vontade de fazer diferente: resolver entupimentos sem enrolação e sem surpresa no preço.
        </p>
      </div>

      <div class="relative">
        <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-primary-100 md:left-1/2 md:-ml-px"></div>
        {timeline.map((item, index) => (
          <div class={`relative mb-12 md:grid md:grid-cols-2 md:gap-12 ${index % 2 === 0 ? '' : 'md:text-right'}`}>
            <div class={`pl-12 md:pl-0 ${index % 2 === 0 ? 'md:pr-12' : 'md:order-2 md:pl-12'}`}>
              <span class="absolute left-0 top-0 flex h-8 w-8 items-center justify-center rounded-full bg-primary text-sm font-bold text-white md:left-1/2 md:-ml-4">
                {index + 1}
              </span>
              <div class="inline-block rounded-full bg-primary-50 px-3 py-1 text-sm font-bold text-primary">
                {item.year}
              </div>
              <h3 class="mt-3 font-display text-xl font-bold text-text">{item.title}</h3>
              <p class="mt-2 text-muted leading-relaxed">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Valores -->
  <section class="border-y border-primary-100 bg-primary-50 py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 max-w-2xl text-center mx-auto">
        <span class="mb-3 block text-sm font-bold tracking-wider text-primary-700 uppercase">O que nos move</span>
        <h2 class="font-display text-3xl font-bold text-text md:text-4xl">Nossos valores</h2>
        <p class="mt-4 text-lg text-muted">
          Cada atendimento é uma chance de provar que desentupimento pode ser rápido, limpo e honesto.
        </p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {values.map((item) => (
          <div class="rounded-2xl bg-white p-10 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg">
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-primary-50 text-primary" aria-hidden="true" set:html={item.svg} />
            <h3 class="mb-3 font-display text-lg font-bold text-text">{item.title}</h3>
            <p class="text-sm leading-relaxed text-muted">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Equipe -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 max-w-2xl">
        <span class="mb-3 block text-sm font-bold tracking-wider text-primary-700 uppercase">Nossa equipe</span>
        <h2 class="font-display text-3xl font-bold text-text md:text-4xl">
          Atendimento humano em cada etapa
        </h2>
        <p class="mt-4 text-lg text-muted">
          Do primeiro contato ao pós-serviço, você fala com gente de verdade que entende sua urgência.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {team.map((item) => (
          <div class="rounded-2xl border border-primary-100 bg-white p-10 shadow-sm">
            <div class="mb-4 font-display text-4xl font-bold text-primary">{item.role.charAt(0)}</div>
            <h3 class="mb-3 font-display text-xl font-bold text-text">{item.role}</h3>
            <p class="leading-relaxed text-muted">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="pb-24 md:pb-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="rounded-3xl bg-dark p-12 text-center text-white md:p-20">
        <h2 class="font-display text-3xl font-bold md:text-5xl">
          Entupimento agora? Chame quem entende.
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-300">
          Atendimento 24h em toda a cidade do Rio de Janeiro. Orçamento grátis, chegada rápida e garantia no serviço.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <Button href={whatsappLink()} variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
            Chamar no WhatsApp
          </Button>
          <Button href="/contato/" variant="outline" size="lg">
            Falar por telefone
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>
