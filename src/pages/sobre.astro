---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Button from '../components/Button.astro';
import { whatsappLink } from '../data/config.ts';

const missionVisionValues = [
  { title: 'Missão', description: 'Resolver entupimentos no Rio de Janeiro com rapidez, limpeza e honestidade, devolvendo o conforto de quem confia em nosso trabalho.', icon: '🎯' },
  { title: 'Visão', description: 'Ser a desentupidora de referência no Rio de Janeiro pelo atendimento 24h, equipe qualificada e compromisso real com o cliente.', icon: '👁️' },
  { title: 'Valores', description: 'Pontualidade, transparência no preço, respeito ao cliente, garantia no serviço e responsabilidade ambiental no descarte de resíduos.', icon: '❤️' },
];

const team = [
  { role: 'Atendimento', description: 'Equipe treinada para entender sua emergência e enviar a equipe técnica mais próxima.' },
  { role: 'Técnicos', description: 'Profissionais experientes com equipamento próprio para cada tipo de entupimento.' },
  { role: 'Pós-atendimento', description: 'Acompanhamento para garantir que o problema foi resolvido e você ficou satisfeito.' },
];
---

<Layout
  title="Sobre a Desentupidora Rio de Janeiro | Atendimento 24h"
  description="Conheça a Desentupidora Rio de Janeiro. Atendimento 24h, equipe treinada, missão, visão e valores.">
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <PageHeader
        eyebrow="Sobre nós"
        title="A desentupidora que o Rio de Janeiro confia"
        description="Há anos ajudando moradores e empresas da cidade a se livrarem de entupimentos com rapidez, limpeza e garantia."
      />

      <!-- Nossa História -->
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div class="space-y-6 text-lg leading-relaxed text-muted">
          <h2 class="font-display text-2xl font-bold text-text">Nossa história</h2>
          <p>
            A Desentupidora Rio de Janeiro nasceu da necessidade de oferecer um serviço
            de desentupimento eficiente, limpo e sem surpresas no preço. Começamos
            atendendo bairros da Zona Norte e, com o tempo, expandimos nossa operação
            para cobrir toda a cidade do Rio de Janeiro.
          </p>
          <p>
            Hoje atuamos 24 horas por dia, em todas as regiões, com equipes próprias e
            equipamento industrial. Residências, comércios, condomínios e indústrias
            contam conosco para resolver desde o ralo entupido até a limpeza completa
            de fossa.
          </p>
          <p>
            Nosso diferencial é simples: chegar rápido, diagnosticar corretamente, resolver
            de verdade e deixar o local limpo. Você só paga quando a água voltar a descer.
          </p>
          <div class="pt-4">
            <Button href={whatsappLink()} variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
              Chamar no WhatsApp
            </Button>
          </div>
        </div>

        <div class="rounded-3xl bg-primary p-12 text-white">
          <div class="grid grid-cols-2 gap-8 text-center">
            <div>
              <div class="font-display text-5xl font-extrabold">+5</div>
              <div class="mt-2 text-sm font-semibold uppercase tracking-wider text-primary-100">Anos de experiência</div>
            </div>
            <div>
              <div class="font-display text-5xl font-extrabold text-primary">24h</div>
              <div class="mt-2 text-sm font-semibold uppercase tracking-wider text-primary-100">Disponibilidade</div>
            </div>
            <div>
              <div class="font-display text-5xl font-extrabold text-accent">100%</div>
              <div class="mt-2 text-sm font-semibold uppercase tracking-wider text-primary-100">Foco no cliente</div>
            </div>
            <div>
              <div class="font-display text-5xl font-extrabold">RJ</div>
              <div class="mt-2 text-sm font-semibold uppercase tracking-wider text-primary-100">Toda cidade</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Missão, Visão e Valores -->
  <section class="border-y border-primary-100 bg-primary-50 py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 max-w-2xl text-center mx-auto">
        <span class="mb-3 block text-sm font-bold tracking-wider text-primary-700 uppercase">Propósito</span>
        <h2 class="font-display text-3xl font-bold text-text md:text-4xl">Missão, visão e valores</h2>
      </div>

      <div class="grid gap-10 md:grid-cols-3">
        {missionVisionValues.map((item) => (
          <div class="rounded-2xl bg-white p-10 shadow-sm text-center">
            <div class="mb-4 text-4xl" aria-hidden="true">{item.icon}</div>
            <h3 class="mb-3 font-display text-xl font-bold text-text">{item.title}</h3>
            <p class="leading-relaxed text-muted">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Compromisso com Qualidade -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div class="order-2 lg:order-1 rounded-3xl bg-secondary-50 p-12">
          <h3 class="mb-6 font-display text-2xl font-bold text-text">Compromisso com qualidade e meio ambiente</h3>
          <ul class="space-y-4 text-muted">
            <li class="flex items-start gap-3">
              <span class="mt-1 text-primary-700">✓</span>
              Equipamento revisado e adequado para cada tipo de tubulação.
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 text-primary-700">✓</span>
              Procedimentos de limpeza que minimizam o impacto ambiental.
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 text-primary-700">✓</span>
              Descarte correto de resíduos de fossa e caixa de gordura.
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 text-primary-700">✓</span>
              Uso de EPIs e normas de segurança para proteger nossos técnicos e clientes.
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 text-primary-700">✓</span>
              Garantia no serviço: reajuste sem custo extra se o problema persistir.
            </li>
          </ul>
        </div>

        <div class="order-1 lg:order-2 space-y-6">
          <span class="text-sm font-bold tracking-wider text-primary-700 uppercase">Qualidade</span>
          <h2 class="font-display text-3xl font-bold text-text md:text-4xl">
            Serviço bem feito do início ao fim
          </h2>
          <p class="text-lg leading-relaxed text-muted">
            Desentupimento não é só passar uma mangueira. É entender a causa do entupimento,
            usar a ferramenta certa, proteger pisos e móveis, e deixar tudo limpo ao final.
          </p>
          <p class="text-lg leading-relaxed text-muted">
            Por isso investimos em equipamento moderno, treinamento constante e processos
            claros. O resultado é um serviço rápido, eficiente e com garantia real.
          </p>
          <Button href="/servicos/" variant="primary" size="lg">
            Conhecer nossos serviços
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Nossa Equipe -->
  <section class="border-t border-primary-100 bg-primary-50 py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="mb-16 max-w-2xl">
        <span class="mb-3 block text-sm font-bold tracking-wider text-primary-700 uppercase">Nossa equipe</span>
        <h2 class="font-display text-3xl font-bold text-text md:text-4xl">
          Atendimento humano em cada etapa
        </h2>
        <p class="mt-4 text-lg text-muted">
          Do primeiro contato ao pós-serviço, você fala com gente de verdade que entende sua urgência.
        </p>
      </div>

      <div class="grid gap-10 md:grid-cols-3">
        {team.map((item) => (
          <div class="rounded-2xl bg-white p-10 shadow-sm">
            <h3 class="mb-3 font-display text-xl font-bold text-text">{item.role}</h3>
            <p class="leading-relaxed text-muted">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
