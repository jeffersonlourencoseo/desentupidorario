---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import Button from '../components/Button.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SchemaBreadcrumbs from '../components/seo/SchemaBreadcrumbs.astro';
import { SITE_CONFIG, whatsappLink, phoneLink, emailLink, mapsLink } from '../data/config.ts';

const channels = [
  { label: 'WhatsApp', value: SITE_CONFIG.phone.replace('+55', '').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3'), href: whatsappLink(), target: '_blank', rel: 'noopener noreferrer' },
  { label: 'Telefone', value: SITE_CONFIG.phone.replace('+55', '').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3'), href: phoneLink() },
  { label: 'E-mail', value: SITE_CONFIG.email, href: emailLink() },
  { label: 'Endereço', value: SITE_CONFIG.fullAddress, href: mapsLink(), target: '_blank', rel: 'noopener noreferrer' },
];

const breadcrumbs = [
  { name: 'Início', url: '/' },
  { name: 'Contato', url: '/contato/', current: true },
];
---

<Layout
  title="Contato"
  description="Entre em contato com a Desentupidora Rio de Janeiro. Atendimento 24h por WhatsApp, telefone ou formulário.">

  <SchemaBreadcrumbs items={breadcrumbs} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <PageHeader
        eyebrow="Contato"
        title="Fale com a Desentupidora RJ"
        description="Emergência de entupimento? Responderemos em minutos. Atendimento 24h por WhatsApp, telefone ou formulário."
      />

      <div class="grid gap-12 lg:grid-cols-2">
        <div class="space-y-8">
          <div class="border-2 border-steel bg-white p-10">
            <h2 class="mb-8 font-display text-3xl uppercase tracking-wide text-ink">Canais de atendimento</h2>
            <ul class="space-y-6">
              {channels.map((channel) => (
                <li class="flex flex-col gap-1">
                  <span class="text-xs font-bold uppercase tracking-wider text-muted">{channel.label}</span>
                  <a
                    href={channel.href}
                    target={channel.target}
                    rel={channel.rel}
                    class="text-lg font-semibold text-ink hover:text-alert transition-colors"
                  >
                    {channel.value}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class="border-2 border-alert bg-ink p-10 text-white">
            <h2 class="mb-4 font-display text-3xl uppercase tracking-wide">Emergência agora?</h2>
            <p class="mb-6 text-white/70">
              Se o esgoto está voltando ou o vaso sanitário pode transbordar, chame nosso
              atendimento emergencial direto pelo WhatsApp. Respondemos em minutos.
            </p>
            <Button href={whatsappLink()} variant="secondary" size="lg" target="_blank" rel="noopener noreferrer">
              Chamar no WhatsApp
            </Button>
            <a href={phoneLink()} class="mt-4 block text-center font-display text-2xl tracking-wide text-white transition-colors hover:text-alert">
              {SITE_CONFIG.phone.replace('+55', '').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3')}
            </a>
          </div>
        </div>

        <div>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</Layout>
