---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Button from '../components/Button.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SchemaBreadcrumbs from '../components/seo/SchemaBreadcrumbs.astro';
import { whatsappLink } from '../data/config.ts';

const allServices = await getCollection('servicos');
const services = allServices.sort((a, b) => a.data.order - b.data.order);

const breadcrumbs = [
  { name: 'Início', url: '/' },
  { name: 'Serviços', url: '/servicos/', current: true },
];
---

<Layout
  title="Serviços"
  description="Conheça todos os serviços da Desentupidora Rio de Janeiro: esgoto, cano, pia, ralo, vaso sanitário, fossa e caixa de gordura.">

  <SchemaBreadcrumbs items={breadcrumbs} />
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-24 md:py-32">
    <div class="container mx-auto px-6 lg:px-12">
      <PageHeader
        eyebrow="Serviços"
        title="Desentupimento completo no Rio de Janeiro"
        description="Do ralo ao esgoto, temos a solução certa para cada tipo de entupimento. Atendimento 24h com orçamento grátis."
      />

      <div class="mb-10 max-w-2xl">
        <h2 class="font-display text-3xl uppercase leading-tight tracking-wide text-ink md:text-4xl">
          Serviços de desentupimento no Rio de Janeiro
        </h2>
        <p class="mt-4 text-muted">
          Soluções para cada tipo de entupimento, com atendimento 24h e equipe treinada.
        </p>
      </div>

      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <a href={`/servicos/${service.id.replace(/\.md$/, '').replace(/\//g, '-')}/`} class="block group">
            <ServiceCard
              title={service.data.title.replace(' no Rio de Janeiro', '')}
              description={service.data.description}
              icon={service.data.icon || ''}
            />
          </a>
        ))}
      </div>

      <div class="mt-16 text-center">
        <Button href={whatsappLink()} variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
          Chamar no WhatsApp
        </Button>
      </div>

      <!-- Conteúdo relacionado -->
      <div class="mt-20 border-2 border-steel bg-white p-10 shadow-[6px_6px_0px_0px_rgba(225,231,236,1)]">
        <h2 class="mb-4 font-display text-2xl font-bold text-text">Conteúdo relacionado</h2>
        <p class="mb-8 text-muted">
          Tire dúvidas sobre desentupimento, aprenda a prevenir entupimentos e descubra quando chamar uma desentupidora.
        </p>
        <div class="grid gap-4 sm:grid-cols-2">
          <a href="/perguntas-frequentes/" class="block border-2 border-steel bg-concrete p-6 transition-all hover:border-alert hover:bg-white">
            <span class="mb-2 block text-xs font-bold uppercase tracking-wider text-alert">FAQ</span>
            <span class="block font-display text-lg uppercase tracking-wide text-ink">Perguntas Frequentes</span>
            <span class="mt-1 block text-sm text-muted">Respostas sobre preço, atendimento, garantia e serviços.</span>
          </a>
          <a href="/blog/" class="block border-2 border-steel bg-concrete p-6 transition-all hover:border-alert hover:bg-white">
            <span class="mb-2 block text-xs font-bold uppercase tracking-wider text-alert">Blog</span>
            <span class="block font-display text-lg uppercase tracking-wide text-ink">Dicas e orientações</span>
            <span class="mt-1 block text-sm text-muted">Como evitar entupimentos e identificar problemas na fossa.</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
