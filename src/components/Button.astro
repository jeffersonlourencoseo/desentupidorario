---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'accent' | 'outline' | 'outline-dark' | 'ghost';
  size?: 'md' | 'lg';
  target?: string;
  rel?: string;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  target,
  rel,
  class: className = '',
} = Astro.props;

const base = 'group relative inline-flex items-center justify-center font-body font-bold uppercase tracking-wide transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 hover:-translate-y-0.5 active:translate-y-0';

const variants = {
  primary: 'bg-ink text-white hover:bg-ink-700 focus:ring-ink',
  secondary: 'bg-alert text-white hover:bg-alert-600 focus:ring-alert',
  accent: 'bg-signal text-ink hover:bg-signal-600 focus:ring-signal',
  outline: 'border-2 border-white text-white hover:bg-white hover:text-ink focus:ring-white',
  'outline-dark': 'border-2 border-ink text-ink hover:bg-ink hover:text-white focus:ring-ink',
  ghost: 'text-ink hover:text-alert underline-offset-4 hover:underline',
};

const sizes = {
  md: 'px-6 py-3 text-sm',
  lg: 'px-8 py-4 text-base',
};
---

<a
  href={href}
  target={target}
  rel={rel}
  class:list={[base, variants[variant], sizes[size], className]}
  role="button">
  <span class="relative z-10 flex items-center gap-2">
    <slot />
  </span>
</a>
