---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'accent' | 'outline' | 'outline-dark';
  size?: 'md' | 'lg';
  target?: string;
  rel?: string;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  target,
  rel,
  class: className = '',
} = Astro.props;

const base = 'inline-flex items-center justify-center rounded-full font-bold transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 hover:scale-105 active:scale-95';

const variants = {
  primary: 'bg-primary text-white hover:bg-primary-600 focus:ring-primary shadow-lg shadow-primary/20',
  secondary: 'bg-secondary text-dark hover:bg-secondary-600 focus:ring-secondary shadow-lg shadow-secondary/20',
  accent: 'bg-accent text-white hover:bg-accent-600 focus:ring-accent shadow-lg shadow-accent/20',
  outline: 'border-2 border-white text-white hover:bg-white/10 focus:ring-white',
  'outline-dark': 'border-2 border-primary text-primary hover:bg-primary hover:text-white focus:ring-primary',
};

const sizes = {
  md: 'px-6 py-3 text-sm',
  lg: 'px-8 py-4 text-base',
};
---

<a
  href={href}
  target={target}
  rel={rel}
  class:list={[base, variants[variant], sizes[size], className]}
  role="button">
  <slot />
</a>
