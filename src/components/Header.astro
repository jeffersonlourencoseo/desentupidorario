---
import { whatsappLink, phoneLink, SITE_CONFIG } from '../data/config.ts';

const nav = [
  { label: 'Home', href: '/' },
  { label: 'Serviços', href: '/servicos/' },
  { label: 'Quem Somos', href: '/quem-somos/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contato', href: '/contato/' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b-2 border-steel bg-white shadow-sm">
  <div class="container mx-auto px-4 sm:px-6 lg:px-12">
    <div class="flex h-16 items-center justify-between sm:h-20">
      <a href="/" class="group flex items-center gap-2 transition-transform hover:scale-[1.02] sm:gap-3" aria-label={SITE_CONFIG.siteName}>
        <span class="flex h-9 w-9 items-center justify-center border-2 border-ink bg-ink text-white transition-all group-hover:bg-alert group-hover:border-alert sm:h-11 sm:w-11">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
            <circle cx="12" cy="12" r="9" />
            <path d="M12 7v5l4 2" />
          </svg>
        </span>
        <div class="leading-none">
          <span class="block font-display text-xl tracking-wide text-ink sm:text-2xl">DESENTUPIDORA</span>
          <span class="block text-[11px] font-bold tracking-[0.12em] text-muted uppercase sm:text-xs">Rio de Janeiro</span>
        </div>
      </a>

      <nav class="hidden items-center gap-1 md:flex" aria-label="Navegação principal">
        {nav.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href.slice(0, -1)));
          return (
            <a
              href={item.href}
              class:list={[
                'px-4 py-2 text-sm font-bold uppercase tracking-wide transition-all hover:bg-ink hover:text-white',
                isActive ? 'bg-ink text-white' : 'text-ink/80',
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <a
        href={whatsappLink()}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-2 bg-alert-700 px-6 py-3 text-sm font-bold uppercase tracking-wide text-white shadow-[4px_4px_0px_0px_rgba(15,43,61,1)] transition-all hover:bg-alert-900 hover:shadow-[2px_2px_0px_0px_rgba(15,43,61,1)] hover:-translate-y-0.5 active:translate-y-0"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.447-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Orçamento grátis
      </a>

      <button
        id="menu-toggle"
        type="button"
        class="flex h-11 w-11 items-center justify-center border-2 border-ink text-ink transition-all hover:bg-ink hover:text-white md:hidden"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="menu-icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Menu mobile drawer -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[999] translate-x-full bg-ink transition-transform duration-300 md:hidden"
  aria-hidden="true"
>
  <div class="flex h-full flex-col px-5 py-6 sm:px-6 sm:py-8">
    <div class="flex items-center justify-between border-b-2 border-white/10 pb-5 sm:pb-6">
      <a href="/" class="flex items-center gap-2 sm:gap-3" aria-label="Desentupidora Rio de Janeiro">
        <span class="flex h-9 w-9 items-center justify-center border-2 border-white bg-white text-ink sm:h-11 sm:w-11">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
            <circle cx="12" cy="12" r="9" />
            <path d="M12 7v5l4 2" />
          </svg>
        </span>
        <div class="leading-none">
          <span class="block font-display text-xl tracking-wide text-white sm:text-2xl">DESENTUPIDORA</span>
          <span class="block text-[11px] font-bold tracking-[0.12em] text-white/70 uppercase sm:text-xs">Rio de Janeiro</span>
        </div>
      </a>

      <button
        id="menu-close"
        type="button"
        class="flex h-11 w-11 items-center justify-center border-2 border-white text-white transition-all hover:bg-signal hover:border-signal hover:text-ink"
        aria-label="Fechar menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <nav class="mt-6 flex flex-col sm:mt-8" aria-label="Navegação mobile">
      {nav.map((item) => {
        const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href.slice(0, -1)));
        return (
          <a
            href={item.href}
            class:list={[
              'mobile-nav-link border-b border-white/10 py-4 font-display text-2xl tracking-wide transition-all hover:pl-4 hover:text-signal sm:py-5 sm:text-3xl',
              isActive ? 'text-signal' : 'text-white',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="mt-auto flex flex-col gap-3 border-t-2 border-white/10 pt-6 sm:gap-4 sm:pt-8">
      <a
        href={whatsappLink()}
        target="_blank"
        rel="noopener noreferrer"
        class="mobile-nav-link inline-flex items-center justify-center gap-2 bg-alert-700 px-4 py-3 text-sm font-bold uppercase tracking-wide text-white sm:px-6 sm:py-4 sm:text-base"
      >
        Orçamento grátis pelo WhatsApp
      </a>
      <a
        href={phoneLink()}
        class="mobile-nav-link text-center font-display text-xl tracking-wide text-white transition-all hover:text-signal sm:text-2xl"
      >
        {SITE_CONFIG.phone.replace('+55', '').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3')}
      </a>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const close = document.getElementById('menu-close');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  function openMenu() {
    if (!menu || !openIcon || !closeIcon || !toggle) return;
    menu.classList.remove('translate-x-full');
    menu.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    openIcon.classList.add('hidden');
    closeIcon.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    if (!menu || !openIcon || !closeIcon || !toggle) return;
    menu.classList.add('translate-x-full');
    menu.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    openIcon.classList.remove('hidden');
    closeIcon.classList.add('hidden');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  close?.addEventListener('click', closeMenu);
  mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
