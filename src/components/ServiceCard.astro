---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<article class="group relative border-2 border-ink bg-white p-8 shadow-[6px_6px_0px_0px_rgba(10,22,40,1)] transition-all hover:-translate-y-1 hover:shadow-[10px_10px_0px_0px_rgba(255,107,0,1)]">
  <div class="mb-6 flex h-14 w-14 items-center justify-center border-2 border-ink bg-signal text-ink transition-all group-hover:bg-alert group-hover:text-white group-hover:border-alert">
    <slot name="icon">
      <span set:html={icon} />
    </slot>
  </div>
  <h3 class="mb-3 font-display text-2xl uppercase tracking-wide text-ink">{title}</h3>
  <p class="text-base leading-relaxed text-muted">{description}</p>
  <div class="mt-6 flex items-center gap-2 text-sm font-bold uppercase tracking-wide text-alert transition-colors group-hover:text-alert-600">
    Saiba mais
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7" />
    </svg>
  </div>
</article>
