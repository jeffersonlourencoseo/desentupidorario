---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<article class="group rounded-2xl border border-primary-100 bg-white p-10 shadow-sm transition-all hover:-translate-y-1 hover:border-secondary/30 hover:shadow-lg">
  <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-primary-50 text-primary transition-colors group-hover:bg-secondary group-hover:text-dark">
    <slot name="icon">
      <span set:html={icon} />
    </slot>
  </div>
  <h3 class="mb-3 font-display text-xl font-bold text-text">{title}</h3>
  <p class="text-base leading-relaxed text-muted">{description}</p>
</article>
