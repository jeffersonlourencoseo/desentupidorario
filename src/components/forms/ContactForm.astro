---
---

<form class="space-y-5 rounded-2xl bg-white p-8 shadow-lg md:p-10" name="contato" method="POST" data-netlify="true" netlify-honeypot="bot-field">
  <p class="hidden">
    <label>
      Não preencha: <input name="bot-field" />
    </label>
  </p>

  <div class="grid gap-5 sm:grid-cols-2">
    <div class="space-y-2">
      <label for="nome" class="text-sm font-semibold text-text">Nome</label>
      <input
        id="nome"
        name="nome"
        type="text"
        required
        class="w-full rounded-xl border border-primary-100 bg-light p-4 text-text outline-none transition-all focus:border-secondary focus:ring-2 focus:ring-secondary/20"
        placeholder="Seu nome"
      />
    </div>
    <div class="space-y-2">
      <label for="telefone" class="text-sm font-semibold text-text">Telefone / WhatsApp</label>
      <input
        id="telefone"
        name="telefone"
        type="tel"
        required
        class="w-full rounded-xl border border-primary-100 bg-light p-4 text-text outline-none transition-all focus:border-secondary focus:ring-2 focus:ring-secondary/20"
        placeholder="(21) 99999-9999"
      />
    </div>
  </div>

  <div class="space-y-2">
    <label for="email" class="text-sm font-semibold text-text">E-mail</label>
    <input
      id="email"
      name="email"
      type="email"
      class="w-full rounded-xl border border-primary-100 bg-light p-4 text-text outline-none transition-all focus:border-secondary focus:ring-2 focus:ring-secondary/20"
      placeholder="seu@email.com"
    />
  </div>

  <div class="space-y-2">
    <label for="endereco" class="text-sm font-semibold text-text">Endereço no Rio de Janeiro</label>
    <input
      id="endereco"
      name="endereco"
      type="text"
      required
      class="w-full rounded-xl border border-primary-100 bg-light p-4 text-text outline-none transition-all focus:border-secondary focus:ring-2 focus:ring-secondary/20"
      placeholder="Bairro e rua"
    />
  </div>

  <div class="space-y-2">
    <label for="servico" class="text-sm font-semibold text-text">Serviço necessário</label>
    <select
      id="servico"
      name="servico"
      class="w-full rounded-xl border border-primary-100 bg-light p-4 text-text outline-none transition-all focus:border-secondary focus:ring-2 focus:ring-secondary/20"
    >
      <option value="">Selecione um serviço</option>
      <option value="desentupimento-de-esgoto">Desentupimento de esgoto</option>
      <option value="desentupimento-de-cano">Desentupimento de cano</option>
      <option value="desentupimento-de-pia">Desentupimento de pia</option>
      <option value="desentupimento-de-ralo">Desentupimento de ralo</option>
      <option value="desentupimento-de-vaso-sanitario">Desentupimento de vaso sanitário</option>
      <option value="limpeza-de-fossa">Limpeza de fossa</option>
      <option value="limpeza-de-caixa-de-gordura">Limpeza de caixa de gordura</option>
      <option value="outro">Outro</option>
    </select>
  </div>

  <div class="space-y-2">
    <label for="mensagem" class="text-sm font-semibold text-text">Mensagem</label>
    <textarea
      id="mensagem"
      name="mensagem"
      rows="4"
      class="w-full rounded-xl border border-primary-100 bg-light p-4 text-text outline-none transition-all focus:border-secondary focus:ring-2 focus:ring-secondary/20"
      placeholder="Descreva o problema com o máximo de detalhes"
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full rounded-full bg-accent p-5 text-base font-bold text-white shadow-lg shadow-accent/20 transition-colors hover:bg-accent-600 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
  >
    Solicitar orçamento grátis
  </button>
</form>
