---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  centered?: boolean;
  light?: boolean;
}

const { eyebrow, title, description, centered = true, light = false } = Astro.props;

const textColor = light ? 'text-white' : 'text-ink';
const mutedColor = light ? 'text-white/70' : 'text-muted';
---

<div class:list={["mb-16 max-w-3xl", centered && "mx-auto text-center"]}>
  {eyebrow && (
    <span class:list={["mb-4 inline-block border border-alert bg-alert px-3 py-1 text-xs font-bold uppercase tracking-wider text-white", light && "border-white/30 bg-white/10 text-white"]}>
      {eyebrow}
    </span>
  )}
  <h1 class:list={["font-display text-5xl uppercase leading-[0.9] tracking-wide md:text-6xl lg:text-7xl", textColor]}>
    {title}
  </h1>
  {description && (
    <p class:list={["mt-6 text-lg leading-relaxed", mutedColor]}>
      {description}
    </p>
  )}
</div>
