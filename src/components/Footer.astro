---
import { SITE_CONFIG, whatsappLink, phoneLink, emailLink } from '../data/config.ts';

const year = new Date().getFullYear();

const links = [
  { label: 'Início', href: '/' },
  { label: 'Serviços', href: '/servicos/' },
  { label: 'Quem Somos', href: '/quem-somos/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contato', href: '/contato/' },
  { label: 'Privacidade', href: '/privacidade/' },
  { label: 'Termos', href: '/termos/' },
];
---

<footer class="border-t-8 border-alert bg-ink pt-20 pb-10 text-white" itemscope itemtype="https://schema.org/LocalBusiness">
  <meta itemprop="name" content={SITE_CONFIG.legalName} />
  <meta itemprop="description" content={SITE_CONFIG.description} />
  <meta itemprop="telephone" content={SITE_CONFIG.phone} />
  <meta itemprop="email" content={SITE_CONFIG.email} />
  <div itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
    <meta itemprop="streetAddress" content={`${SITE_CONFIG.address.street}, ${SITE_CONFIG.address.number}`} />
    <meta itemprop="addressLocality" content={SITE_CONFIG.address.city} />
    <meta itemprop="addressRegion" content={SITE_CONFIG.address.state} />
    <meta itemprop="postalCode" content={SITE_CONFIG.address.postalCode} />
    <meta itemprop="addressCountry" content={SITE_CONFIG.address.country} />
  </div>

  <div class="container mx-auto px-6 lg:px-12">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3">
          <span class="flex h-12 w-12 items-center justify-center border-2 border-signal bg-signal text-ink">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 7v5l4 2" />
            </svg>
          </span>
          <div class="leading-none">
            <span class="block font-display text-3xl tracking-wide">DESENTUPIDORA</span>
            <span class="block text-xs font-bold tracking-[0.2em] text-signal uppercase">Rio de Janeiro</span>
          </div>
        </div>
        <p class="mt-6 max-w-md text-base leading-relaxed text-white/70">
          Atendimento 24 horas em toda a cidade do Rio de Janeiro. Resolvemos entupimentos com rapidez,
          equipamento profissional e garantia real de serviço.
        </p>
        <a
          href={whatsappLink()}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex items-center gap-2 border-2 border-signal bg-signal px-6 py-3 text-sm font-bold uppercase tracking-wide text-ink transition-all hover:-translate-y-0.5 active:translate-y-0"
        >
          Chamar no WhatsApp
        </a>
      </div>

      <div>
        <h3 class="mb-5 font-display text-xl uppercase tracking-wide text-signal">Mapa do site</h3>
        <ul class="space-y-3 text-sm">
          {links.map((link) => (
            <li>
              <a href={link.href} class="font-medium text-white/80 transition-colors hover:text-alert hover:underline">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-5 font-display text-xl uppercase tracking-wide text-signal">Contato</h3>
        <ul class="space-y-4 text-sm">
          <li class="flex flex-col">
            <span class="text-xs font-bold uppercase tracking-wide text-white/50">WhatsApp</span>
            <a href={whatsappLink()} class="text-lg font-bold text-white transition-colors hover:text-alert">
              {SITE_CONFIG.phone.replace('+55', '').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3')}
            </a>
          </li>
          <li class="flex flex-col">
            <span class="text-xs font-bold uppercase tracking-wide text-white/50">E-mail</span>
            <a href={emailLink()} class="font-medium text-white transition-colors hover:text-alert">{SITE_CONFIG.email}</a>
          </li>
          <li class="flex flex-col">
            <span class="text-xs font-bold uppercase tracking-wide text-white/50">Endereço</span>
            <span class="font-medium text-white">{SITE_CONFIG.fullAddress}</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-16 border-t-2 border-white/10 pt-8 flex flex-col items-center justify-between gap-4 md:flex-row">
      <p class="text-center text-xs text-white/50 md:text-left">
        © {year} {SITE_CONFIG.siteName}. Todos os direitos reservados.
      </p>
      <div class="flex gap-6 text-xs font-bold uppercase tracking-wide text-white/50">
        <a href="/privacidade/" class="transition-colors hover:text-alert">Privacidade</a>
        <a href="/termos/" class="transition-colors hover:text-alert">Termos</a>
      </div>
    </div>
  </div>
</footer>
