---
import { SITE_CONFIG, whatsappLink, phoneLink, emailLink, mapsLink } from '../data/config.ts';

const year = new Date().getFullYear();

const links = [
  { label: 'Início', href: '/' },
  { label: 'Serviços', href: '/servicos/' },
  { label: 'Quem Somos', href: '/quem-somos/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contato', href: '/contato/' },
  { label: 'Privacidade', href: '/privacidade/' },
  { label: 'Termos', href: '/termos/' },
];
---

<footer class="border-t-4 border-steel bg-ink pt-14 pb-20 text-white sm:pt-20 sm:pb-24" itemscope itemtype="https://schema.org/LocalBusiness">
  <meta itemprop="name" content={SITE_CONFIG.legalName} />
  <meta itemprop="description" content={SITE_CONFIG.description} />
  <meta itemprop="telephone" content={SITE_CONFIG.phone} />
  <meta itemprop="email" content={SITE_CONFIG.email} />
  <div itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
    <meta itemprop="streetAddress" content={`${SITE_CONFIG.address.street}, ${SITE_CONFIG.address.number}`} />
    <meta itemprop="addressLocality" content={SITE_CONFIG.address.city} />
    <meta itemprop="addressRegion" content={SITE_CONFIG.address.state} />
    <meta itemprop="postalCode" content={SITE_CONFIG.address.postalCode} />
    <meta itemprop="addressCountry" content={SITE_CONFIG.address.country} />
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-12">
    <div class="grid gap-10 sm:gap-12 md:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center border-2 border-white bg-white text-ink sm:h-12 sm:w-12">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 7v5l4 2" />
            </svg>
          </span>
          <div class="leading-none">
            <span class="block font-display text-2xl tracking-wide">DESENTUPIDORA</span>
            <span class="block text-[10px] font-bold tracking-[0.2em] text-white/50 uppercase sm:text-xs">Rio de Janeiro</span>
          </div>
        </div>
        <p class="mt-5 max-w-md text-sm leading-relaxed text-white/60 sm:mt-6 sm:text-base">
          Atendimento 24 horas em toda a cidade do Rio de Janeiro. Resolvemos entupimentos com rapidez,
          equipamento profissional e garantia de serviço.
        </p>
        <a
          href={whatsappLink()}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-5 inline-flex items-center gap-2 bg-alert-700 px-5 py-2.5 text-xs font-bold uppercase tracking-wide text-white transition-all hover:-translate-y-0.5 active:translate-y-0 sm:mt-6 sm:px-6 sm:py-3 sm:text-sm"
        >
          Chamar no WhatsApp
        </a>
      </div>

      <div>
        <h3 class="mb-4 font-display text-lg uppercase tracking-wide text-white sm:mb-5 sm:text-xl">Mapa do site</h3>
        <ul class="space-y-2.5 text-sm">
          {links.map((link) => (
            <li>
              <a href={link.href} class="font-medium text-white/70 transition-colors hover:text-signal hover:underline">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 font-display text-lg uppercase tracking-wide text-white sm:mb-5 sm:text-xl">Contato</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex flex-col">
            <span class="text-xs font-bold uppercase tracking-wide text-white/70">WhatsApp</span>
            <a href={whatsappLink()} class="text-base font-bold text-white transition-colors hover:text-alert sm:text-lg">
              {SITE_CONFIG.phone.replace('+55', '').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3')}
            </a>
          </li>
          <li class="flex flex-col">
            <span class="text-xs font-bold uppercase tracking-wide text-white/70">E-mail</span>
            <a href={emailLink()} class="font-medium text-white transition-colors hover:text-alert">{SITE_CONFIG.email}</a>
          </li>
          <li class="flex flex-col">
            <span class="text-xs font-bold uppercase tracking-wide text-white/70">Endereço</span>
            <a href={mapsLink()} target="_blank" rel="noopener noreferrer" class="font-medium text-white transition-colors hover:text-alert">
              {SITE_CONFIG.fullAddress}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t-2 border-white/10 pt-6 sm:mt-16 sm:pt-8 md:flex-row">
      <p class="text-center text-xs text-white/70 md:text-left">
        © {year} {SITE_CONFIG.siteName}. Todos os direitos reservados.
      </p>
      <div class="flex gap-4 text-xs font-bold uppercase tracking-wide text-white/70 sm:gap-6">
        <a href="/privacidade/" class="transition-colors hover:text-alert">Privacidade</a>
        <a href="/termos/" class="transition-colors hover:text-alert">Termos</a>
      </div>
    </div>
  </div>
</footer>
