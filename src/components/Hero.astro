---
import Button from './Button.astro';
import { whatsappLink } from '../data/config.ts';
---

<section class="relative overflow-hidden bg-primary py-24 text-white md:py-32">
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
      <defs>
        <pattern id="wave" width="10" height="10" patternUnits="userSpaceOnUse">
          <path d="M0 5 Q2.5 0 5 5 T10 5" fill="none" stroke="currentColor" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#wave)" />
    </svg>
  </div>

  <div class="container relative mx-auto px-6 lg:px-12">
    <div class="max-w-3xl">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm font-semibold backdrop-blur-sm">
        <span class="h-2 w-2 rounded-full bg-secondary animate-pulse"></span>
        Atendimento 24h no Rio de Janeiro
      </div>

      <h1 class="font-display text-4xl font-extrabold leading-tight md:text-6xl">
        Desentupidora no Rio de Janeiro
      </h1>

      <p class="mt-6 text-lg leading-relaxed text-primary-50 md:text-xl">
        Resolvemos entupimentos de esgoto, canos, pias, ralos, vasos sanitários,
        fossas e caixas de gordura. Chegamos rápido em toda a cidade, com
        orçamento grátis e garantia no serviço.
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <Button href={whatsappLink()} variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
          Chamar no WhatsApp
        </Button>
        <Button href="/servicos/" variant="outline" size="lg">
          Ver nossos serviços
        </Button>
      </div>

      <div class="mt-12 flex flex-wrap gap-8 text-sm font-semibold text-primary-100">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
          Garantia no serviço
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
          Atendimento rápido
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2v20M2 12h20" />
          </svg>
          Orçamento grátis
        </div>
      </div>
    </div>
  </div>
</section>
