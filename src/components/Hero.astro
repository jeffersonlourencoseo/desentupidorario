---
import Button from './Button.astro';
import { whatsappLink } from '../data/config.ts';
---

<section class="relative overflow-hidden bg-ink py-20 text-white md:py-28">
  <!-- Padrão de grade sutil -->
  <div class="absolute inset-0 opacity-[0.06]" aria-hidden="true">
    <svg class="h-full w-full" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M 60 0 L 0 0 0 60" fill="none" stroke="currentColor" stroke-width="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="absolute -right-20 top-0 h-[140%] w-24 -rotate-12 bg-alert/90 md:w-36" aria-hidden="true"></div>
  <div class="absolute -left-10 bottom-0 h-48 w-[140%] -rotate-6 bg-white/5 md:h-64" aria-hidden="true"></div>

  <div class="container relative mx-auto px-6 lg:px-12">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <div class="max-w-2xl">
        <div class="mb-6 inline-flex items-center gap-3 border border-white/20 bg-white/5 px-4 py-2">
          <span class="h-3 w-3 animate-pulse bg-alert"></span>
          <span class="text-sm font-bold uppercase tracking-wider text-white/90">Atendimento 24h no Rio</span>
        </div>

        <h1 class="font-display text-6xl font-normal uppercase leading-[0.9] tracking-wide md:text-8xl">
          Desentupidora{' '}
          <span class="block text-alert">Rio de Janeiro</span>
        </h1>

        <p class="mt-8 max-w-xl text-lg leading-relaxed text-white/70 md:text-xl">
          Resolvemos entupimentos de esgoto, canos, pias, ralos, vasos sanitários, fossas e caixas de gordura.
          Chegamos rápido em toda a cidade, com orçamento grátis e garantia no serviço.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <Button href={whatsappLink()} variant="secondary" size="lg" target="_blank" rel="noopener noreferrer">
            Chamar no WhatsApp
          </Button>
          <Button href="/servicos/" variant="outline" size="lg">
            Ver Serviços
          </Button>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-4 border border-white/20"></div>
        <div class="relative border-2 border-white bg-white p-8 text-ink shadow-[12px_12px_0px_0px_rgba(217,92,30,1)] md:p-12">
          <div class="mb-6 flex items-center gap-3">
            <span class="flex h-10 w-10 items-center justify-center bg-alert text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </span>
            <span class="font-display text-2xl uppercase tracking-wide">Emergência 24h</span>
          </div>

          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <span class="mt-1 text-alert">✓</span>
              <span class="font-body text-muted">Atendimento em toda a cidade do Rio</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="mt-1 text-alert">✓</span>
              <span class="font-body text-muted">Orçamento grátis antes de executar</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="mt-1 text-alert">✓</span>
              <span class="font-body text-muted">Equipamento profissional para cada caso</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="mt-1 text-alert">✓</span>
              <span class="font-body text-muted">Garantia real no serviço feito</span>
            </div>
          </div>

          <div class="mt-8 border-t-2 border-steel pt-6">
            <div class="font-body text-xs font-bold uppercase tracking-wider text-muted">WhatsApp</div>
            <a href={whatsappLink()} class="mt-1 block font-display text-4xl text-alert transition-colors hover:text-alert-600">
              (21) 99775-1577
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
