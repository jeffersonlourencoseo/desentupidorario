---
import { SITE_CONFIG } from '../../data/config.ts';

interface Props {
  title: string;
  description: string;
  url: string;
  image?: string;
  pubDate: Date;
  modDate?: Date;
}

const { title, description, url, image = `${SITE_CONFIG.domain}/og-image.svg`, pubDate, modDate, author: authorName } = Astro.props;

const dateIso = (d: Date) => d.toISOString();

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image,
  url,
  datePublished: dateIso(pubDate),
  dateModified: dateIso(modDate || pubDate),
  author: authorName
    ? { '@type': 'Person', name: authorName }
    : {
        '@type': 'Organization',
        name: SITE_CONFIG.legalName,
        url: SITE_CONFIG.domain,
      },
  publisher: {
    '@type': 'Organization',
    name: SITE_CONFIG.legalName,
    url: SITE_CONFIG.domain,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE_CONFIG.domain}/og-image.svg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': url,
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
