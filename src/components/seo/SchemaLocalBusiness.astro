---
import { SITE_CONFIG } from '../../data/config.ts';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE_CONFIG.legalName,
  description: SITE_CONFIG.description,
  url: SITE_CONFIG.domain,
  telephone: SITE_CONFIG.phone,
  email: SITE_CONFIG.email,
  priceRange: SITE_CONFIG.priceRange,
  image: `${SITE_CONFIG.domain}/og-image.svg`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: `${SITE_CONFIG.address.street}, ${SITE_CONFIG.address.number}`,
    addressLocality: SITE_CONFIG.address.city,
    addressRegion: SITE_CONFIG.address.state,
    postalCode: SITE_CONFIG.address.postalCode,
    addressCountry: SITE_CONFIG.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '-22.8395',
    longitude: '-43.2543',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '23:59',
    },
  ],
  areaServed: {
    '@type': 'City',
    name: SITE_CONFIG.city,
    containedInPlace: {
      '@type': 'State',
      name: SITE_CONFIG.state,
      containedInPlace: {
        '@type': 'Country',
        name: 'Brasil',
      },
    },
  },
  sameAs: [
    `https://wa.me/${SITE_CONFIG.whatsapp}`,
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
